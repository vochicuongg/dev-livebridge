<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/flashlight_notification_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:layoutDirection="ltr"
    android:orientation="vertical"
    android:paddingBottom="2dp">

    <TextView
        android:id="@+id/flashlight_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="#FFF5F7FA"
        android:textSize="14sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="24dp"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:id="@+id/flashlight_slider_track"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <FrameLayout
                    android:layout_width="22dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_flashlight_slider_track_start" />

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_flashlight_slider_track_middle" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_flashlight_slider_track_middle" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_flashlight_slider_track_middle" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_flashlight_slider_track_middle" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_flashlight_slider_track_middle" />

                <FrameLayout
                    android:layout_width="22dp"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_flashlight_slider_track_end" />

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <FrameLayout
                android:id="@+id/flashlight_segment_slot_1"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:foregroundGravity="center">

                <ImageView
                    android:id="@+id/flashlight_segment_1"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/flashlight_segment_inactive" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/flashlight_segment_slot_2"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:foregroundGravity="center">

                <ImageView
                    android:id="@+id/flashlight_segment_2"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/flashlight_segment_inactive" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/flashlight_segment_slot_3"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:foregroundGravity="center">

                <ImageView
                    android:id="@+id/flashlight_segment_3"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/flashlight_segment_inactive" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/flashlight_segment_slot_4"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:foregroundGravity="center">

                <ImageView
                    android:id="@+id/flashlight_segment_4"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/flashlight_segment_inactive" />
            </FrameLayout>

            <FrameLayout
                android:id="@+id/flashlight_segment_slot_5"
                android:layout_width="0dp"
                android:layout_height="24dp"
                android:layout_weight="1"
                android:foregroundGravity="center">

                <ImageView
                    android:id="@+id/flashlight_segment_5"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_gravity="center"
                    android:src="@drawable/flashlight_segment_inactive" />
            </FrameLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/flashlight_disabled_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#33000000"
            android:text=""
            android:visibility="gone" />
    </FrameLayout>

    <TextView
        android:id="@+id/flashlight_action_button"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_flashlight_action_button"
        android:gravity="center"
        android:textColor="#FFF5F7FA"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
