  "weather_condition_fog_pattern": "(mist|fog|haze)",
  "weather_condition_wind_pattern": "(wind|windy|gust)",
  "weather_condition_sun_pattern": "(sunny|clear)",
  "weather_condition_cloud_pattern": "(cloud|overcast)",
