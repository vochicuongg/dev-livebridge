  "weather_context_pattern": "(weather|temperature|feels like|humidity|wind|precip|pressure|forecast|uv|aqi|today|tomorrow|highs?|lows?|sunny|clear|cloudy|overcast|rain(?:y)?|snow(?:y)?|fog(?:gy)?|mist|haze|wind(?:y)?|gust(?:y)?|thunder(?:storm)?|storm(?:y)?)",
  "weather_temperature_pattern": "(?<!\\d)([+\\-−]?\\d{1,3})\\s*(?:°(?:\\s*(?:c|f)(?!\\p{L}))?|℃|℉)",
  "weather_day_pattern": "(today|tomorrow|morning|afternoon|evening|night)",
  "weather_condition_pattern": "(sunny|cloudy|overcast|rain|snow|fog|windy|clear)",
  "weather_condition_thunder_pattern": "(thunder|storm)",
  "weather_condition_rain_pattern": "(rain|shower)",
