  "otp_loose_trigger_pattern": "(?:(?:\\bcode\\b|\\botp\\b|\\bpasscode\\b|\\bpassword\\b|kata\\s+sandi|\\bsandi\\b|\\bkode\\b)\\s*[:#-]?[\\s]*\\d(?:[\\s-]?\\d){3,7})",
  "money_context_pattern": "(₽|\\$|€|￥|¥|rub|usd|eur|kzt|price|total|amount|sum|twd|nt\\$|rmb|cny|hkd)",
  "text_progress_percent_pattern": "(?<!\\d)(\\d{1,3})\\s*%",
  "text_progress_context_window": 80,
  "text_progress_include_context_pattern": "(remaining|progress|completed|completing|downloading|uploading|updating|installing|sync(?:ing)?|processing|processed|render(?:ing)?|encoding|decoding)",
  "text_progress_exclude_context_pattern": "(discount|promo|coupon|sale|cashback|off\\b|bonus|save|deal|special\\s+offer|limited\\s+time|minimum\\s+order|order\\s+from|\\d{2,7}\\s*(?:usd|eur|\\$|€|kzt)|humidity|weather|temperature|pressure|precip|commission|fee\\b|tax\\b|apr\\b)",
  "weather_package_hints": [
    "weather",
    "sec.android.daemonapp",
    "meteo",
    "accuweather",
    "weatherchannel",
    "gismeteo",
    "yandex.weather",
