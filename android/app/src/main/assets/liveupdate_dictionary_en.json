  "navigation_distance_pattern": "(?<!\\d)\\d{1,4}(?:[\\s.,]\\d{1,2})?\\s*(?:km|m|mi|ft)\\b",
  "navigation_instruction_pattern": "(turn\\s+(?:left|right)|keep\\s+(?:left|right)|take\\s+exit|u-?turn|roundabout)",
  "otp_strong_triggers": [
