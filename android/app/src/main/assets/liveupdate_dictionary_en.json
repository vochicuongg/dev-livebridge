{
  "smart_rules": [
    {
      "id": "food",
      "max_stage": 4,
      "package_hints": [
        "kfc",
        "ubereats",
        "doordash",
        "grubhub",
        "delivery",
        "ozon",
        "ru.ozon.app.android",
        "food",
        "meituan",
        "eleme",
        "foodpanda",
        "zepto",
        "zomato",
        "swiggy",
        "blinkit",
        "instamart",
        "bigbasket"
      ],
      "text_triggers": [
        "order",
        "courier",
        "food",
        "restaurant"
      ],
      "exclude_patterns": [
        "(happy birthday|birthday)",
        "(discount|\\d+%\\s*off|promo\\s*code|coupon|cash\\s*back|cashback|sale)",
        "(payment\\s*(?:failure|failed|declined|unsuccessful))",
        "(order\\s+from\\s*\\d)",
        "(tracking|shipment|parcel|pickup\\s*point)",
        "(you'?ll\\s+get\\s+an\\s+alert[^\\n]{0,80}(?:at\\s+your\\s+door|delivered)|keep\\s+your\\s+phone\\s+nearby\\s+until\\s+it'?s\\s+delivered|until\\s+it'?s\\s+delivered)"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(delivery completed|order delivered|delivered|completed|enjoy(?: your (?:meal|order))?|thanks for ordering)"
        },
        {
          "stage": 3,
          "pattern": "(out for delivery|on the way|heading to you|courier[^\\n]*(picked up|heading|on the way|nearby)|give[^\\n]{0,60}a\\s+moment\\s+to\\s+leave\\s+your\\s+order\\s+at\\s+the\\s+door)"
        },
        {
          "stage": 2,
          "pattern": "(order[^\\n]{0,40}(ready(?:\\s+for\\s+(?:pickup|delivery))?)|ready for pickup|ready for delivery|packed|almost ready)"
        },
        {
          "stage": 1,
          "pattern": "(order[^\\n]{0,40}(preparing|in kitchen|being prepared|being cooked|cooking|assembling)|preparing|in kitchen|is being prepared|is being cooked|being cooked|cooking|assembling)"
        },
        {
          "stage": 0,
          "pattern": "(order[^\\n]*(received|accepted|confirmed|created|placed|paid)|payment[^\\n]*(successful|confirmed|received|accepted))"
        }
      ]
    },
    {
      "id": "taxi",
      "max_stage": 4,
      "package_hints": [
        "taxi",
        "uber",
        "lyft",
        "bolt",
        "yango",
        "yandex",
        "didi",
        "grab"
      ],
      "text_triggers": [
        "taxi",
        "ride",
        "driver"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(trip completed|arrived at destination|you'?ve arrived)"
        },
        {
          "stage": 3,
          "pattern": "(trip started|ride started|enjoy your ride)"
        },
        {
          "stage": 2,
          "pattern": "(driver[^\\n]*arriving|arriving in|on the way)"
        },
        {
          "stage": 1,
          "pattern": "(driver found|driver assigned|matched with driver)"
        },
        {
          "stage": 0,
          "pattern": "(searching for (a )?driver|finding driver)"
        }
      ]
    },
    {
      "id": "navigation",
      "max_stage": 4,
      "package_hints": [
        "ru.dublgis.dgismobile",
        "dublgis",
        "ru.yandex.yandexmaps",
        "google.android.apps.maps",
        "waze",
        "here",
        "tomtom",
        "maps",
        "map",
        "navigator",
        "navigation",
        "navi",
        "amap",
        "baidu.BaiduMap",
        "citymapper"
      ],
      "text_triggers": [
        "route",
        "turn left",
        "turn right",
        "keep left",
        "keep right",
        "take exit",
        "u-turn",
        "roundabout",
        "destination"
      ],
      "exclude_patterns": [
        "(happy birthday|birthday)",
        "(discount|\\d+%\\s*off|promo\\s*code|coupon|cash\\s*back|cashback|sale)",
        "(unsubscribe|newsletter|follow us|download app)"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(finish the route|arrived|destination reached|you'?ve arrived)"
        },
        {
          "stage": 3,
          "pattern": "(destination (is )?on (your )?(right|left)|almost there)"
        },
        {
          "stage": 2,
          "pattern": "(\\b\\d+\\s*(m|km|ft|mi)\\b|turn (left|right)|keep (left|right)|continue|head\\s|take\\s+the|exit|merge|roundabout|u-?turn)"
        },
        {
          "stage": 1,
          "pattern": "(navigation started|starting route|follow the route|route started)"
        }
      ]
    },
    {
      "id": "external_device",
      "max_stage": 2,
      "package_hints": [
        "camera",
        "bluetooth",
        "accessory",
        "usb",
        "gopro",
        "dji",
        "wearable",
        "galaxywearable",
        "miui"
      ],
      "text_triggers": [
        "camera",
        "bluetooth",
        "accessory",
        "usb",
        "gopro",
        "dji",
        "pair",
        "connected",
        "connecting",
        "is connected"
      ],
      "exclude_patterns": [
        "(happy birthday|birthday)",
        "(discount|\\d+%\\s*off|promo\\s*code|coupon|cash\\s*back|cashback|sale)",
        "(hotspot|personal\\s+hotspot|tether(?:ing)?|wifi\\s+hotspot|\\b\\d+\\s+devices?\\b)"
      ],
      "signals": [
        {
          "stage": 2,
          "pattern": "(connected\\b|pair(?:ed)?\\b)"
        },
        {
          "stage": 1,
          "pattern": "(connecting\\b|pair(?:ing)?\\b)"
        }
      ]
    },
    {
      "id": "vpn",
      "max_stage": 1,
      "package_hints": [
        "vpn",
        "wireguard",
        "openvpn",
        "nordvpn",
        "protonvpn",
        "surfshark",
        "expressvpn",
        "outline",
        "amnezia",
        "clash",
        "v2ray",
        "hiddify",
        "llc.itdev.incy",
        "tailscale",
        "zerotier",
        "shadowsocks"
      ],
      "text_triggers": [
        "vpn",
        "wireguard",
        "openvpn",
        "tunnel",
        "secure connection"
      ],
      "signals": [
        {
          "stage": 1,
          "pattern": "(?<!\\d)\\d{1,4}(?:[.,]\\d{1,2})?\\s*(?:[kmg]?i?b)\\s*(?:(?:/\\s*s)|(?:/\\s*sec)|ps)\\b|connected"
        }
      ]
    }
  ],
  "blocked_source_packages": [],
  "privacy_redaction_placeholders": [
    "sensitive content hidden",
    "content hidden",
    "hidden content",
