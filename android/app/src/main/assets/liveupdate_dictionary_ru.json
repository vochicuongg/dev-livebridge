    "navigator",
    ".maps",
    "navi"
  ],
  "navigation_distance_pattern": "(?<!\\d)\\d{1,4}(?:[\\s.,]\\d{1,2})?\\s*(?:км|km|м|m|mi|ft|миль|фут)\\b",
  "navigation_instruction_pattern": "(поверните[^\\n,.;:!]*|сверните[^\\n,.;:!]*|держитесь[^\\n,.;:!]*|развернитесь)",
  "otp_strong_triggers": [
    "код подтверждения",
    "код подтверждения входа",
    "код для подтверждения",
    "код проверки",
    "проверочный код",
    "код верификации",
    "код авторизации",
    "код безопасности",
    "код входа",
    "код для входа в аккаунт",
    "код для подтверждения входа",
    "код для входа",
    "код для добавления",
    "код для добавления устройства",
    "код подтверждения операции",
    "код оплаты",
    "код аккаунта",
    "одноразовый",
    "код из смс"
  ],
  "otp_loose_trigger_pattern": "(?:(?:\\bкод\\b|\\bпароль\\b|одноразов(?:ый|ого))\\s*[:#-]?[\\s]*\\d(?:[\\s-]?\\d){3,7})",
  "money_context_pattern": "(₽|\\$|€|￥|¥|руб\\.?|тенге|р\\.|сумм|цена|стоимост|итого)",
  "text_progress_percent_pattern": "(?<!\\d)(\\d{1,3})\\s*%",
  "text_progress_context_window": 80,
  "text_progress_include_context_pattern": "(прогресс|выполн(?:ен|ено|яется|ение)|загруз(?:к|жается|жено)|скач(?:ив|ивает|ивание)|обновл(?:ен|ение|яется)|синхрон(?:изац|изируется)|обработ(?:к|ан|ает)|установ(?:к|лен))",
  "text_progress_exclude_context_pattern": "(скид|акци|промокод|промо|купон|распрод|кэшб[еэ]к|кешб[еэ]к|выгод|бонус|дарим|подар|при\\s+заказ|при\\s+покуп|в\\s+приложени\\S*\\s+акци|\\d{2,7}\\s*(?:₽|руб\\.?|рубл(?:ей|я|ь)?|rur|usd|eur|\\$|€|kzt|тенге)|влажност|погод|температур|давлен|осадк|комисси|налог|\\bставк(?:а|и|у|е|ой|ах|ам|ами)?\\b|годов(?:ых|ая)?\\s*процент|процентн(?:ая|ые|ых)\\s+ставк|ипотек|кредит|депозит|вклад|сбор\\b|маркетплейс|посыл(?:к|ок)|почт[аы])",
  "weather_package_hints": [
    "weather",
    "sec.android.daemonapp",
    "meteo",
    "accuweather",
    "weatherchannel",
    "gismeteo",
    "yandex.weather",
