  "weather_context_pattern": "(погод|температур|ощущаетс|влажност|ветер|осадк|давлен|прогноз)",
  "weather_temperature_pattern": "(?<!\\d)([+\\-−]?\\d{1,3})\\s*(?:°(?:\\s*(?:c|f|с|ф)(?!\\p{L}))?|℃|℉)",
  "weather_day_pattern": "(сегодня|завтра|утром|днем|вечером|ночью)",
  "weather_condition_pattern": "(ясно|пасмурно|облачно|дожд|снег|туман|ветрено|солнечно)",
  "weather_condition_thunder_pattern": "(гроз)",
  "weather_condition_rain_pattern": "(дожд)",
  "weather_condition_snow_pattern": "(снег)",
  "weather_condition_fog_pattern": "(туман)",
  "weather_condition_wind_pattern": "(ветер|ветрено)",
  "weather_condition_sun_pattern": "(солнечно|ясно)",
  "weather_condition_cloud_pattern": "(пасмурно|облачно)",
  "external_device_name_patterns": [
    "(?:подключ(?:ен(?:а|о|ы)?|ается|ение)|соедин(?:ен(?:а|о|ы)?|яется))\\s*(?:к)?\\s*[\"«]?([\\p{L}\\p{N}][\\p{L}\\p{N} ._#\\-]{1,40})[\"»]?(?=\\s|$|[,.!])",
    "[\"«]?([\\p{L}\\p{N}][\\p{L}\\p{N} ._#\\-]{1,40})[\"»]?\\s*(?:подключ(?:ен(?:а|о|ы)?|ается|ение)|соедин(?:ен(?:а|о|ы)?|яется))\\b"
  ],
