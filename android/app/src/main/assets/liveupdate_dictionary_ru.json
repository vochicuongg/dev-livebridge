{
  "smart_rules": [
    {
      "id": "food",
      "max_stage": 4,
      "package_hints": [
        "kfc",
        "ubereats",
        "doordash",
        "grubhub",
        "delivery",
        "ozon",
        "ru.ozon.app.android",
        "еда",
        "food",
        "meituan",
        "eleme",
        "foodpanda",
        "zepto",
        "zomato",
        "swiggy",
        "blinkit",
        "instamart",
        "bigbasket"
      ],
      "text_triggers": [
        "заказ",
        "курьер",
        "еда",
        "ресторан"
      ],
      "exclude_patterns": [
        "(с дн[её]м рождения)",
        "(дарим\\s+скидк|скидк[\\p{L}]*\\s*\\d+%|\\d+%\\s*(скидк|off)|акци[яи]|промокод|кэшб[еэ]к)",
        "(оплат[аы][^\\n]*(?:не\\s*прошл|ошибк|отклон|не\\s*успеш)|неудачн[а-я\\s]*оплат)",
        "(корзин|заверш(?:ите|ить)\\s+оформлени|оформите\\s+заказ|перейдите\\s+к\\s+оформлени|продолж(?:ите|ить)\\s+оформлени)",
        "(при\\s+заказе\\s+от\\s*\\d)",
        "(почт[аы]\\s+росси|посыл(?:к|ок)|маркетплейс|отделени[ея]|трек-?номер|пункт\\s*выдачи)"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(доставлен(?:а|о|ы)?|получен(?:а|о|ы)?|вручен(?:а|о|ы)?|приятного аппетита)"
        },
        {
          "stage": 3,
          "pattern": "(курьер[^\\n]*(в пути|едет|уже рядом|подъезжа(?:ет|л)|забрал(?: заказ)?)|едет к вам|вез[её]м\\s+заказ|заказ[^\\n]{0,30}вез[её]м|доставля(?:ется|ем|ют)|передан[^\\n]*курьеру)"
        },
        {
          "stage": 2,
          "pattern": "(заказ[^\\n]{0,40}(готов(?:\\b|\\s)|собран|упакован|готов к выдаче|готов для выдачи|готов к самовывозу)|собран(?:о|ы)?\\b|упакован(?:о|ы)?\\b|готов к выдаче|готов для выдачи|готов к самовывозу)"
        },
        {
          "stage": 1,
          "pattern": "(заказ[^\\n]{0,40}(собира(?:ем|ют|ется)|готов(?:ится|им|ят)|начали готовить|в работе|в процессе)|собира(?:ем|ют|ется)[^\\n]{0,30}заказ)"
        },
        {
          "stage": 0,
          "pattern": "(заказ[^\\n]*(принят|создан|оформлен(?:а|о|ы)?\\b|подтвержд[её]н|оплачен)|оплат[аы][^\\n]*(прошла|подтверждена|успешна|принята))"
        }
      ]
    },
    {
      "id": "taxi",
      "max_stage": 4,
      "package_hints": [
        "taxi",
        "uber",
        "lyft",
        "bolt",
        "yango",
        "yandex",
        "didi",
        "grab"
      ],
      "text_triggers": [
        "такси",
        "поездка",
        "водитель"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(поездка завершена)"
        },
        {
          "stage": 3,
          "pattern": "(поездка началась)"
        },
        {
          "stage": 2,
          "pattern": "(едет к вам|подъезжает)"
        },
        {
          "stage": 1,
          "pattern": "(водитель найден)"
        },
        {
          "stage": 0,
          "pattern": "(поиск[^\\n]*водител|ищем[^\\n]*водител)"
        }
      ]
    },
    {
      "id": "navigation",
      "max_stage": 4,
      "package_hints": [
        "ru.dublgis.dgismobile",
        "dublgis",
        "ru.yandex.yandexmaps",
        "google.android.apps.maps",
        "waze",
        "here",
        "tomtom",
        "maps",
        "map",
        "navigator",
        "navigation",
        "navi",
        "amap",
        "baidu.BaiduMap",
        "citymapper"
      ],
      "text_triggers": [
        "маршрут",
        "навигац",
        "поверните",
        "сверните",
        "развернитесь",
        "пункт назначения",
        "съезд",
        "кругов"
      ],
      "exclude_patterns": [
        "(с дн[её]м рождения)",
        "(дарим\\s+скидк|скидк[\\p{L}]*\\s*\\d+%|\\d+%\\s*(скидк|off)|акци[яи]|промокод|кэшб[еэ]к)",
        "(вы получили это письмо|отписаться от рассыл|скачать приложение)"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(вы прибыли|пункт назначения достигнут|маршрут заверш[её]н|завершить маршрут)"
        },
        {
          "stage": 3,
          "pattern": "(пункт назначения[^\\n]*(справа|слева)|почти на месте|до пункта назначения)"
        },
        {
          "stage": 2,
          "pattern": "(через\\s*\\d+[\\d\\s.,]*(м|км|m|km|ft|mi)|поверните|сверните|держитесь|развернитесь|пройдите|двигайтесь|продолжайте движение|возьмите съезд|выйдите)"
        },
        {
          "stage": 1,
          "pattern": "(маршрут построен|маршрут начат)"
        }
      ]
    },
    {
      "id": "external_device",
      "max_stage": 2,
      "package_hints": [
        "camera",
        "bluetooth",
        "accessory",
        "usb",
        "gopro",
        "dji",
        "wearable",
        "galaxywearable",
        "miui"
      ],
      "text_triggers": [
        "подключ",
        "соедин"
      ],
      "exclude_patterns": [
        "(с дн[её]м рождения)",
        "(дарим\\s+скидк|скидк[\\p{L}]*\\s*\\d+%|\\d+%\\s*(скидк|off)|акци[яи]|промокод|кэшб[еэ]к)",
        "(точк[аеи]\\s+доступа|раздач[аи]\\s+интернета|клиент(?:ов|ы)?\\s+подключ(?:ен|ено|ены)?)"
      ],
      "signals": [
        {
          "stage": 2,
          "pattern": "(подключ(?:ен(?:а|о|ы)?|ено)\\b|соедин(?:ен(?:а|о|ы)?|ено)\\b)"
        },
        {
          "stage": 1,
          "pattern": "(подключ(?:ается|ение)\\b|соедин(?:яется|ение)\\b)"
        }
      ]
    },
    {
      "id": "vpn",
      "max_stage": 1,
      "package_hints": [
        "vpn",
        "wireguard",
        "openvpn",
        "nordvpn",
        "protonvpn",
        "surfshark",
        "expressvpn",
        "outline",
        "amnezia",
        "clash",
        "v2ray",
        "hiddify",
        "llc.itdev.incy",
        "tailscale",
        "zerotier",
        "shadowsocks"
      ],
      "text_triggers": [
        "туннел",
        "защищенн",
        "виртуальн"
      ],
      "signals": [
        {
          "stage": 1,
          "pattern": "(?<!\\d)\\d{1,4}(?:[.,]\\d{1,2})?\\s*(?:[kmgт]?i?[bб])\\s*(?:(?:/\\s*[sс])|(?:/\\s*sec)|ps)\\b|подключено"
        }
      ]
    }
  ],
  "blocked_source_packages": [],
  "privacy_redaction_placeholders": [
    "sensitive content hidden",
    "content hidden",
    "hidden content",
    "notification content hidden",
    "unlock to view",
    "содержимое скрыто",
    "контент скрыт",
