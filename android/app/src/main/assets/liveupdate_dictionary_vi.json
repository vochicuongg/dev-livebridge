  ],
  "otp_loose_trigger_pattern": "(?:(?:\\bmã\\b|\\botp\\b|\\bmật khẩu\\b)\\s*[:#-]?[\\s]*\\d(?:[\\s-]?\\d){3,7})",
  "money_context_pattern": "(₫|đồng|vnd|\\$|€|₽)",
  "text_progress_percent_pattern": "(?<!\\d)(\\d{1,3})\\s*%",
  "text_progress_context_window": 80,
  "text_progress_include_context_pattern": "(còn lại|hoàn tất|tải xuống|tải lên|cập nhật|cài đặt|xử lý|đồng bộ)",
  "text_progress_exclude_context_pattern": "(giảm giá|khuyến mãi|hoàn tiền|thưởng|thời tiết)",
  "weather_package_hints": [
    "weather",
    "sec.android.daemonapp",
    "meteo",
    "accuweather",
    "weatherchannel",
    "gismeteo",
    "yandex.weather",
    "pogoda",
    "clime",
    "1weather",
    "todayweather"
  ],
  "weather_context_pattern": "(thời tiết|nhiệt độ|độ ẩm|gió|mưa|áp suất|dự báo|nắng|mây|sấm)",
  "weather_temperature_pattern": "(?<!\\d)([+\\-−]?\\d{1,3})\\s*(?:°(?:\\s*(?:c|f)(?!\\p{L}))?|℃|℉)",
  "weather_day_pattern": "(hôm nay|ngày mai|sáng|chiều|tối|đêm)",
  "weather_condition_pattern": "(nắng|mây|mưa|tuyết|sương mù|gió)",
  "weather_condition_thunder_pattern": "(sấm|giông|bão)",
  "weather_condition_rain_pattern": "(mưa|mưa rào)",
  "weather_condition_snow_pattern": "(tuyết|mưa đá)",
  "weather_condition_fog_pattern": "(sương mù|sương)",
  "weather_condition_wind_pattern": "(gió|gió mạnh)",
  "weather_condition_sun_pattern": "(nắng|trời quang)",
  "weather_condition_cloud_pattern": "(mây|u ám|nhiều mây)",
  "external_device_name_patterns": [
    "(?:connected|connecting|pair(?:ed|ing)|đã kết nối|đang kết nối)\\s*(?:to|với)?\\s*[\"«]?([\\p{L}\\p{N}][\\p{L}\\p{N} ._#\\-]{1,40})[\"»]?(?=\\s|$|[,.!])",
    "[\"«]?([\\p{L}\\p{N}][\\p{L}\\p{N} ._#\\-]{1,40})[\"»]?\\s*(?:is\\s+)?(?:đã kết nối|đang kết nối)\\b"
  ],
  "external_device_generic_names": [
