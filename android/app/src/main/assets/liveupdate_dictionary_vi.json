{
  "smart_rules": [
    {
      "id": "food",
      "max_stage": 4,
      "package_hints": [
        "kfc",
        "ubereats",
        "doordash",
        "grubhub",
        "delivery",
        "food",
        "meituan",
        "eleme",
        "foodpanda",
        "zepto",
        "zomato",
        "swiggy",
        "blinkit",
        "instamart",
        "bigbasket",
        "grab",
        "shopee",
        "baemin",
        "gojek",
        "loship",
        "beamin"
      ],
      "text_triggers": [
        "đơn hàng",
        "giao hàng",
        "đồ ăn",
        "nhà hàng",
        "tài xế",
        "shipper"
      ],
      "exclude_patterns": [
        "(sinh nhật|chúc mừng)",
        "(giảm giá|mã giảm|khuyến mãi|voucher|hoàn tiền)"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(đã giao|giao thành công|hoàn tất|cảm ơn bạn đã đặt)"
        },
        {
          "stage": 3,
          "pattern": "(đang giao|trên đường|tài xế đang đến|shipper đang đến|sắp đến)"
        },
        {
          "stage": 2,
          "pattern": "(đã lấy hàng|sẵn sàng giao|đã chuẩn bị xong|đã đóng gói)"
        },
        {
          "stage": 1,
          "pattern": "(đang chuẩn bị|đang nấu|nhà hàng đang chuẩn bị)"
        },
        {
          "stage": 0,
          "pattern": "(đã đặt|đã xác nhận|đã thanh toán|đã nhận đơn)"
        }
      ]
    },
    {
      "id": "taxi",
      "max_stage": 4,
      "package_hints": [
        "taxi",
        "uber",
        "lyft",
        "bolt",
        "yango",
        "yandex",
        "didi",
        "grab",
        "be",
        "gojek",
        "xanh"
      ],
      "text_triggers": [
        "taxi",
        "chuyến xe",
        "tài xế",
        "đón"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(đã đến nơi|kết thúc chuyến|hoàn tất chuyến)"
        },
        {
          "stage": 3,
          "pattern": "(đang di chuyển|bắt đầu chuyến)"
        },
        {
          "stage": 2,
          "pattern": "(tài xế đang đến|sắp đến điểm đón|đang tới)"
        },
        {
          "stage": 1,
          "pattern": "(đã tìm thấy tài xế|tài xế đã nhận)"
        },
        {
          "stage": 0,
          "pattern": "(đang tìm tài xế|tìm tài xế)"
        }
      ]
    },
    {
      "id": "navigation",
      "max_stage": 4,
      "package_hints": [
        "ru.dublgis.dgismobile",
        "dublgis",
        "ru.yandex.yandexmaps",
        "google.android.apps.maps",
        "waze",
        "here",
        "tomtom",
        "maps",
        "map",
        "navigator",
        "navigation",
        "navi",
        "amap",
        "baidu.BaiduMap",
        "citymapper"
      ],
      "text_triggers": [
        "rẽ trái",
        "rẽ phải",
        "đi thẳng",
        "quay đầu",
        "điểm đến"
      ],
      "exclude_patterns": [
        "(sinh nhật)",
        "(giảm giá|khuyến mãi)"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(đã đến|kết thúc dẫn đường|đã tới điểm đến)"
        },
        {
          "stage": 3,
          "pattern": "(sắp đến|gần tới)"
        },
        {
          "stage": 2,
          "pattern": "(\\b\\d+\\s*(m|km|ft|mi)\\b|rẽ (trái|phải)|đi thẳng|quay đầu|vòng xuyến)"
        },
        {
          "stage": 1,
          "pattern": "(bắt đầu dẫn đường|bắt đầu lộ trình)"
        }
      ]
    },
    {
      "id": "external_device",
      "max_stage": 2,
      "package_hints": [
        "camera",
        "bluetooth",
        "accessory",
        "usb",
        "gopro",
        "dji",
        "wearable",
        "galaxywearable",
        "miui"
      ],
      "text_triggers": [
        "máy ảnh",
        "bluetooth",
        "phụ kiện",
        "đã kết nối",
        "đang kết nối"
      ],
      "exclude_patterns": [
        "(sinh nhật)",
        "(giảm giá|khuyến mãi)",
        "(điểm phát sóng|hotspot)"
      ],
      "signals": [
        {
          "stage": 2,
          "pattern": "(đã kết nối\\b|pair(?:ed)?\\b)"
        },
        {
          "stage": 1,
          "pattern": "(đang kết nối\\b|pair(?:ing)?\\b)"
        }
      ]
    },
    {
      "id": "vpn",
      "max_stage": 1,
      "package_hints": [
        "vpn",
        "wireguard",
        "openvpn",
        "nordvpn",
        "protonvpn",
        "surfshark",
        "expressvpn",
        "outline",
        "amnezia",
        "clash",
        "v2ray",
        "hiddify",
        "llc.itdev.incy",
        "tailscale",
        "zerotier",
        "shadowsocks"
      ],
      "text_triggers": [
        "vpn",
        "kết nối bảo mật"
      ],
      "signals": [
        {
          "stage": 1,
          "pattern": "(?<!\\d)\\d{1,4}(?:[.,]\\d{1,2})?\\s*(?:[kmg]?i?b)\\s*(?:(?:/\\s*s)|(?:/\\s*sec)|ps)\\b|đã kết nối"
        }
      ]
    }
  ],
  "blocked_source_packages": [],
  "privacy_redaction_placeholders": [
    "sensitive content hidden",
    "content hidden",
    "hidden content",
    "notification content hidden",
    "unlock to view",
    "nội dung ẩn",
    "mở khóa để xem"
  ],
  "known_navigation_packages": [
    "ru.dublgis.dgismobile",
    "ru.yandex.yandexmaps",
    "com.google.android.apps.maps",
    "com.waze",
    "com.autonavi.minimap",
    "com.baidu.BaiduMap"
  ],
  "navigation_package_markers": [
    "navigation",
    "navigator",
    ".maps",
    "navi"
  ],
  "navigation_distance_pattern": "(?<!\\d)\\d{1,4}(?:[\\s.,]\\d{1,2})?\\s*(?:km|m|mi|ft)\\b",
  "navigation_instruction_pattern": "(rẽ trái|rẽ phải|quay đầu|vòng xuyến|đi thẳng)",
  "otp_strong_triggers": [
    "mã otp",
    "mã xác minh",
    "mã xác nhận",
    "mã đăng nhập",
    "mã bảo mật",
    "mật khẩu",
