{
  "smart_rules": [
    {
      "id": "food",
      "max_stage": 4,
      "package_hints": [
        "kfc",
        "ubereats",
        "doordash",
        "grubhub",
        "delivery",
        "ozon",
        "ru.ozon.app.android",
        "exampleapp",
        "eats",
        "food",
        "meituan",
        "eleme",
        "foodpanda",
        "zepto",
        "zomato",
        "swiggy",
        "blinkit",
        "instamart",
        "bigbasket"
      ],
      "text_triggers": [
        "주문",
        "배달",
        "오더",
        "음식"
      ],
      "exclude_patterns": [
        "(생일)",
        "(할인|쿠폰)"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(배달이 완료되었습니다.)"
        },
        {
          "stage": 3,
          "pattern": "(라이더님이 곧 도착해요!|주문이 거의 도착했습니다.)"
        },
        {
          "stage": 2,
          "pattern": "(라이더님이 배달을 시작했어요|배달원이 고객님의 음식을 픽업했습니다.)"
        },
        {
          "stage": 1,
          "pattern": "(주문이 접수됐어요)"
        },
        {
          "stage": 0,
          "pattern": "(주문 완료)"
        }
      ]
    },
    {
      "id": "taxi",
      "max_stage": 4,
      "package_hints": [
        "taxi",
        "uber",
        "lyft",
        "bolt",
        "yango",
        "yandex",
        "didi",
        "grab"
      ],
      "text_triggers": [
        "taxi",
        "ride",
        "driver"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(목적지에 도착했습니다.)"
        },
        {
          "stage": 3,
          "pattern": "(기사님이 출발지에 도착하였습니다.)"
        },
        {
          "stage": 2,
          "pattern": "(기사님이 도착해요.)"
        },
        {
          "stage": 1,
          "pattern": "(기사님이 배차되었습니다.)"
        },
        {
          "stage": 0,
          "pattern": "(기사님을 찾는 중입니다.)"
        }
      ]
    },
    {
      "id": "navigation",
      "max_stage": 4,
      "package_hints": [
        "ru.dublgis.dgismobile",
        "dublgis",
        "ru.yandex.yandexmaps",
        "google.android.apps.maps",
        "waze",
        "here",
        "tomtom",
        "maps",
        "map",
        "navigator",
        "navigation",
        "navi",
        "nmap",
        "amap",
        "baidu.BaiduMap",
        "citymapper"
      ],
      "text_triggers": [
        "좌회전",
        "우회전",
        "직진",
        "유턴",
        "목적지까지"
      ],
      "exclude_patterns": [
        "(생일)",
        "(할인|쿠폰)"
      ],
      "signals": [
        {
          "stage": 4,
          "pattern": "(길안내를 종료합니다.)"
        },
        {
          "stage": 3,
          "pattern": "(이번 정류장에서 하차)"
        },
        {
          "stage": 2,
          "pattern": "(승차)"
        },
        {
          "stage": 1,
          "pattern": "(길안내를 시작합니다)"
        }
      ]
    },
    {
      "id": "external_device",
      "max_stage": 2,
      "package_hints": [
        "camera",
        "bluetooth",
        "accessory",
        "usb",
        "gopro",
        "dji",
        "wearable",
        "galaxywearable",
        "miui"
      ],
      "text_triggers": [
        "카메라",
        "블루투스",
        "액세서리",
        "연결됨"
      ],
      "exclude_patterns": [
        "(생일)",
        "(할인|쿠폰)",
        "(핫스팟|네트워크)"
      ],
      "signals": [
        {
          "stage": 2,
          "pattern": "(연결됨\\b|pair(?:ed)?\\b)"
        },
        {
          "stage": 1,
          "pattern": "(연결 중\\b|pair(?:ing)?\\b)"
        }
      ]
    },
    {
      "id": "vpn",
      "max_stage": 1,
      "package_hints": [
        "vpn",
        "wireguard",
        "openvpn",
        "nordvpn",
        "protonvpn",
        "surfshark",
        "expressvpn",
        "outline",
        "amnezia",
        "clash",
        "v2ray",
        "hiddify",
        "llc.itdev.incy",
        "tailscale",
        "zerotier",
        "shadowsocks"
      ],
      "text_triggers": [
        "보안 연결"
      ],
      "signals": [
        {
          "stage": 1,
          "pattern": "연결됨"
        }
      ]
    }
  ],
  "blocked_source_packages": [],
  "privacy_redaction_placeholders": [
    "sensitive content hidden",
    "content hidden",
    "hidden content",
    "notification content hidden",
    "unlock to view",
    "민감한 알림 콘텐츠 숨김"
  ],
  "known_navigation_packages": [
    "ru.dublgis.dgismobile",
    "ru.yandex.yandexmaps",
    "com.google.android.apps.maps",
    "com.waze",
    "com.autonavi.minimap",
    "com.baidu.BaiduMap",
    "com.nhn.android.nmap"
  ],
  "navigation_package_markers": [
    "navigation",
    "navigator",
    ".maps",
    "navi"
  ],
  "navigation_distance_pattern": "(?<!\\d)\\d{1,4}(?:[\\s.,]\\d{1,2})?\\s*(?:km|m|mi|ft)\\b",
  "navigation_instruction_pattern": "(좌회전|우회전)",
  "otp_strong_triggers": [
    "인증번호",
    "인증 번호",
    "확인코드",
    "확인 코드"
  ],
  "otp_loose_trigger_pattern": "(?:(?:\\b코드\\b|\\botp\\b|\\b번호\\b|\\b코드\\b)\\s*[:#-]?[\\s]*\\d(?:[\\s-]?\\d){3,7})",
  "money_context_pattern": "(₽|\\$|€|￥|¥|₩|루블|달러|유로)",
  "text_progress_percent_pattern": "(?<!\\d)(\\d{1,3})\\s*%",
  "text_progress_context_window": 80,
  "text_progress_include_context_pattern": "(남음|완료|다운로드|업로드|업데이트|설치|처리)",
  "text_progress_exclude_context_pattern": "(할인|쿠폰|캐시백|보너스|날씨)",
  "weather_package_hints": [
    "weather",
    "sec.android.daemonapp",
    "meteo",
    "accuweather",
    "weatherchannel",
    "gismeteo",
    "yandex.weather",
    "pogoda",
    "clime",
    "1weather",
    "todayweather"
  ],
  "weather_context_pattern": "(날씨|온도|습도|바람|강수|기압|기상|내일|구름|비|천둥)",
  "weather_temperature_pattern": "(?<!\\d)([+\\-−]?\\d{1,3})\\s*(?:°(?:\\s*(?:c|f)(?!\\p{L}))?|℃|℉)",
  "weather_day_pattern": "(오늘|내일|오전|오후|아침|저녁)",
  "weather_condition_pattern": "(맑음|흐림|비|눈|안개)",
  "weather_condition_thunder_pattern": "(천둥|번개)",
  "weather_condition_rain_pattern": "(비)",
  "weather_condition_snow_pattern": "(눈)",
  "weather_condition_fog_pattern": "(안개)",
  "weather_condition_wind_pattern": "(바람)",
  "weather_condition_sun_pattern": "(맑음)",
  "weather_condition_cloud_pattern": "(흐림)",
  "external_device_name_patterns": [
    "(?:connected|connecting|pair(?:ed|ing))\\s*(?:to)?\\s*[\"«]?([\\p{L}\\p{N}][\\p{L}\\p{N} ._#\\-]{1,40})[\"»]?(?=\\s|$|[,.!])",
    "[\"«]?([\\p{L}\\p{N}][\\p{L}\\p{N} ._#\\-]{1,40})[\"»]?\\s*(?:is\\s+)?(?:연결\\b"
  ],
  "external_device_generic_names": [
    "기기",
    "카메라",
    "핫스팟"
  ],
  "vpn_speed_pattern": "(?<!\\d)\\d{1,4}(?:[.,]\\d{1,2})?\\s*(?:[kmg]?i?b)\\s*(?:(?:/\\s*s)|(?:/\\s*sec)|ps)\\b",
  "vpn_context_pattern": "(프록시)",
  "vpn_package_markers": [
    "hiddify",
    "wireguard",
    "openvpn",
    "nordvpn",
    "protonvpn",
    "surfshark",
    "expressvpn",
    "outline",
    "amnezia",
    "clash",
    "v2ray",
    "hysteria",
    "singbox",
    "llc.itdev.incy",
    "tailscale",
    "zerotier",
    "shadowsocks",
    "vpn"
  ],
  "vpn_download_markers": [
    "↓",
    "dl",
    "downlink",
    "download",
    "down",
    "rx",
    "recv",
    "receive",
    "incoming",
    "inbound",
    "ingress"
  ],
  "vpn_upload_markers": [
    "↑",
    "ul",
    "uplink",
    "upload",
    "up",
    "tx",
    "send",
    "outgoing",
    "outbound",
    "egress"
  ],
  "otp_code_patterns": [
    "(?:\\b코드\\b|\\b번호\\b)[^\\d\\n]{0,80}(\\d(?:[\\s-]?\\d){3,7})(?!\\d)",
    "(?<!\\S)(\\d{4,8})(?!\\d)",
    "(?<!\\S)(\\d(?:[\\s-]?\\d){3,7})(?!\\d)",
    "(?<!\\S)([A-Z0-9]{4,8})(?!\\w)"
  ],
  "order_context_hints": [
    "주문",
    "배달"
  ],
  "entity_token_patterns": [
    "(?:#|№)\\s*([a-zA-Z0-9-]{2,16})"
  ],
